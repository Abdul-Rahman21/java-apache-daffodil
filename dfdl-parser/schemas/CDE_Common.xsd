<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<xsd:schema xmlns:dfdl="http://www.ogf.org/dfdl/dfdl-1.0/" xmlns:ibmDfdlExtn="http://www.ibm.com/dfdl/extensions" xmlns:ibmSchExtn="http://www.ibm.com/schema/extensions" xmlns:recSepFieldsFmt="http://www.ibm.com/dfdl/RecordSeparatedFieldFormat" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    	
  
  <xsd:import namespace="http://www.ibm.com/dfdl/RecordSeparatedFieldFormat" schemaLocation="RecordSeparatedFieldFormat.xsd"/>
                                                                                	                    
  
  <xsd:complexType name="TYPE_CityList">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element dfdl:length="1" dfdl:lengthKind="explicit" name="Dot" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq '.'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                  
      
      <xsd:element dfdl:occursCountKind="implicit" maxOccurs="9" name="Cities">
                        
        
        <xsd:complexType>
                              
          
          <xsd:sequence dfdl:separator="">
                                    
            
            <xsd:element name="CityCode" type="TYPE_CityCode"/>
                                    
            
            <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_Slash" type="TYPE_GS_Slash"/>
                                  
          
          </xsd:sequence>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                            
      
      <xsd:element dfdl:initiator="*" dfdl:occursCountKind="implicit" minOccurs="0" name="Currency" type="TYPE_CurrencyCode">
                                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/"/>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                                
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="BFCGroup">
                        
        
        <xsd:complexType>
                              
          
          <xsd:sequence dfdl:separator="">
                                    
            
            <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparator" type="TYPE_GS_PipeSeparator"/>
                                    
            
            <xsd:element name="BFC">
                                      
              
              <xsd:annotation>
                                            
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
              
            </xsd:appinfo>
                                          
              
              </xsd:annotation>
                                                                
              
              <xsd:complexType>
                                                
                
                <xsd:sequence dfdl:separator="">
                                                      
                  
                  <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="BFCAt" type="xsd:string">
                                                            
                    
                    <xsd:annotation>
                                                                  
                      
                      <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                                        
                        
                        <dfdl:discriminator>{. eq 'BFC-'}</dfdl:discriminator>
                                                                      
                      
                      </xsd:appinfo>
                                                                
                    
                    </xsd:annotation>
                                                          
                  
                  </xsd:element>
                                                      
                  
                  <xsd:element name="BrandCode">
                                                            
                    
                    <xsd:complexType>
                                                                  
                      
                      <xsd:sequence dfdl:separator="">
                                                                        
                        
                        <xsd:element dfdl:initiator="@ or ^" name="BFCAt" type="xsd:string">
                                                              
                          
                          <xsd:annotation>
                                                                    
                            
                            <xsd:appinfo source="http://www.ogf.org/dfdl/">
              
            </xsd:appinfo>
                                                                  
                          
                          </xsd:annotation>
                                                            
                        
                        </xsd:element>
                                                                                              
                      
                      </xsd:sequence>
                                                                
                    
                    </xsd:complexType>
                                                          
                  
                  </xsd:element>
                                                    
                
                </xsd:sequence>
                                              
              
              </xsd:complexType>
                                                    
            
            </xsd:element>
                                  
          
          </xsd:sequence>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_PricingOrBestBuy">
            
    
    <xsd:choice>
                  
      
      <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="Pricing" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq '$-$-' or . eq '$:$:' }</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                  
      
      <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" name="BestBuy" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq 'LA$' or . eq 'LP$' }</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                
    
    </xsd:choice>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_PillowPillow">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element name="PricingOrBestBuy" type="TYPE_PricingOrBestBuy"/>
                  
      
      <xsd:element name="GS_AtSignDouble" type="TYPE_GS_AtSignDouble"/>
                  
      
      <xsd:element dfdl:terminator="! or # or ] or %#x1c;" name="Item" type="xsd:string"/>
                              
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparaator" type="TYPE_GS_PipeSeparator"/>
                        
      
      <xsd:element dfdl:occursCountKind="implicit" dfdl:terminator="%#x1c;" minOccurs="0" name="AccountCode" type="TYPE_AccountCode"/>
                                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_TKTDesignator">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element name="GS_Slash" type="TYPE_GS_Slash"/>
                  
      
      <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="Year" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{fn:contains('23',fn:substring(.,1,1)) and 
fn:contains('0123456789',fn:substring(.,2,1))}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                  
      
      <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="TicketDesignator4" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,1,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,2,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,3,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,4,1))}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                            
      
      <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="TicketDesignator3" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,1,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,2,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,3,1))}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                        
      
      <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="TicketDesidnator2" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,1,1)) and 
fn:contains('ABCDEDFGHIJKLMNOPQRSTUVWXYZ0123456789',fn:substring(.,2,1))}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_WithholdSurchargeOverride">
            
    
    <xsd:sequence dfdl:separator="">
                                                      
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="PricingOrBestBuy">
                        
        
        <xsd:complexType>
                              
          
          <xsd:choice>
                                    
            
            <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="Pricing" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq '$-$-' or . eq '$:$:' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                    
            
            <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" name="BestBuy" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq 'LA$' or . eq 'LP$' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                  
          
          </xsd:choice>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                                    
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparator" type="TYPE_GS_PipeSeparator"/>
                        
      
      <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="WithholdOverride" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq 'WQ'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                                                                                          
      
      <xsd:element dfdl:length="1" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="Dot" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq '.'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                        
                                                                                                                                                                                                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="WithholdOverrideGroup">
                        
        
        <xsd:complexType>
                              
          
          <xsd:sequence dfdl:separator="">
                                    
            
            <xsd:element dfdl:length="1" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="Carrier" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq 'C'}</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                    
            
            <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="AirlineCode" type="TYPE_AirlineCode"/>
                                    
            
            <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_Slash" type="TYPE_GS_Slash"/>
                                  
          
          </xsd:sequence>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_T-Pricing">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="T-" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq 'T-' or . eq 'T:'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="NameSelect" type="TYPE_NameSelect"/>
                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="ZOff" type="TYPE_ZOff"/>
                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="Remaining" type="xsd:string"/>
                
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_AccountCode">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="PricingOrBestBuy">
                        
        
        <xsd:complexType>
                                
          
          <xsd:choice>
                                        
            
            <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="Pricing" type="xsd:string">
                                              
              
              <xsd:annotation>
                                                    
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                          
                  
                  <dfdl:discriminator>{. eq '$-$-' or . eq '$:$:' }</dfdl:discriminator>
                                                        
                
                </xsd:appinfo>
                                                  
              
              </xsd:annotation>
                                            
            
            </xsd:element>
                                        
            
            <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" name="BestBuy" type="xsd:string">
                                              
              
              <xsd:annotation>
                                                    
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                          
                  
                  <dfdl:discriminator>{. eq 'LA$' or . eq 'LP$' }</dfdl:discriminator>
                                                        
                
                </xsd:appinfo>
                                                  
              
              </xsd:annotation>
                                            
            
            </xsd:element>
                                                                                                        
          
          </xsd:choice>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                              
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparator" type="TYPE_GS_PipeSeparator"/>
                        
      
      <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="AccountCodeInd" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq '*AC*'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                                                    
      
      <xsd:choice>
                        
        
        <xsd:element dfdl:terminator="#.AC or !.AC" name="AccountCodeOnly" type="xsd:string"/>
                        
        
        <xsd:element dfdl:terminator="# or !" name="AccountCodeAnd" type="xsd:string"/>
                        
        
        <xsd:element name="AccountCode" type="xsd:string"/>
                      
      
      </xsd:choice>
                                                
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="TicketDesignator" type="TYPE_TicketDesignator"/>
                                                    
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="SpecifiedBookingCode" type="TYPE_SpecifiedBookingCode"/>
                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_FareBasisValue">
            
    
    <xsd:choice>
                  
      
      <xsd:element dfdl:terminator="# or !" name="FareBasisValue" type="xsd:string"/>
                  
      
      <xsd:element name="FareBasisValueLast" type="xsd:string"/>
                
    
    </xsd:choice>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_QSurcharge">
            
    
    <xsd:sequence dfdl:separator="">
                  
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparator" type="TYPE_GS_PipeSeparator"/>
                
      
      <xsd:choice>
                      
        
        <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="AQ" type="xsd:string">
                            
          
          <xsd:annotation>
                                  
            
            <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                        
              
              <dfdl:discriminator>{. eq 'AQ'}</dfdl:discriminator>
                                      
            
            </xsd:appinfo>
                                
          
          </xsd:annotation>
                          
        
        </xsd:element>
                      
        
        <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="PQ" type="xsd:string">
                            
          
          <xsd:annotation>
                                  
            
            <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                        
              
              <dfdl:discriminator>{. eq 'PQ'}</dfdl:discriminator>
                                      
            
            </xsd:appinfo>
                                
          
          </xsd:annotation>
                          
        
        </xsd:element>
                                              
        
        <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="WQ" type="xsd:string">
                            
          
          <xsd:annotation>
                                  
            
            <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                        
              
              <dfdl:discriminator>{. eq 'WQ'}</dfdl:discriminator>
                                      
            
            </xsd:appinfo>
                                
          
          </xsd:annotation>
                          
        
        </xsd:element>
                                        
      
      </xsd:choice>
                
    
    </xsd:sequence>
          
  
  </xsd:complexType>
            
  
  <xsd:complexType name="TYPE_AddTax">
            
    
    <xsd:sequence dfdl:separator="">
                        
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="PricingOrBestBuy">
                        
        
        <xsd:complexType>
                              
          
          <xsd:choice>
                                    
            
            <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="Pricing" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq '$-$-' or . eq '$:$:' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                    
            
            <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" name="BestBuy" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq 'LA$' or . eq 'LP$' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                  
          
          </xsd:choice>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                        
      
      <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" name="AddTax" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq 'AT'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                                                                                          
      
      <xsd:element dfdl:length="1" dfdl:lengthKind="explicit" name="Dot" type="xsd:string">
                        
        
        <xsd:annotation>
                              
          
          <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                    
            
            <dfdl:discriminator>{. eq '.'}</dfdl:discriminator>
                                  
          
          </xsd:appinfo>
                            
        
        </xsd:annotation>
                      
      
      </xsd:element>
                        
                                                                                              
      
      <xsd:element dfdl:occursCountKind="implicit" maxOccurs="3" name="AddTaxGroup">
                        
        
        <xsd:complexType>
                              
          
          <xsd:sequence dfdl:separator="">
                                        
            
            <xsd:element name="CountryCode" type="TYPE_CountryCode"/>
                                                                                                                                                    
            
            <xsd:element dfdl:length="2" dfdl:lengthKind="explicit" dfdl:terminator="A" name="Amount" type="xsd:string">
                                    
              
              <xsd:annotation>
                                          
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                
                  
                  <dfdl:discriminator>{fn:contains('0123456789',fn:substring(.,1,1)) and 
fn:contains('0123456789',fn:substring(.,2,1))}</dfdl:discriminator>
                                              
                
                </xsd:appinfo>
                                        
              
              </xsd:annotation>
                                  
            
            </xsd:element>
                                                                                                
            
            <xsd:element dfdl:length="1" dfdl:lengthKind="explicit" dfdl:occursCountKind="implicit" minOccurs="0" name="AmountOrPercent" type="xsd:string">
                                    
              
              <xsd:annotation>
                                          
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                
                  
                  <dfdl:discriminator>{fn:contains('AP',fn:substring(.,1,1))}</dfdl:discriminator>
                                              
                
                </xsd:appinfo>
                                        
              
              </xsd:annotation>
                                  
            
            </xsd:element>
                                                                                                                                                              
            
            <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_Slash" type="TYPE_GS_Slash"/>
                                                                                                                          
          
          </xsd:sequence>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                                    
    
    </xsd:sequence>
          
  
  </xsd:complexType>
        
  
  <xsd:complexType name="TYPE_WithoutTax">
            
    
    <xsd:sequence dfdl:separator="">
                                                      
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="PricingOrBestBuy">
                        
        
        <xsd:complexType>
                              
          
          <xsd:choice>
                                    
            
            <xsd:element dfdl:length="4" dfdl:lengthKind="explicit" name="Pricing" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq '$-$-' or . eq '$:$:' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                    
            
            <xsd:element dfdl:length="3" dfdl:lengthKind="explicit" name="BestBuy" type="xsd:string">
                                          
              
              <xsd:annotation>
                                                
                
                <xsd:appinfo source="http://www.ogf.org/dfdl/">
                                                      
                  
                  <dfdl:discriminator>{. eq 'LA$' or . eq 'LP$' }</dfdl:discriminator>
                                                    
                
                </xsd:appinfo>
                                              
              
              </xsd:annotation>
                                        
            
            </xsd:element>
                                  
          
          </xsd:choice>
                            
        
        </xsd:complexType>
                      
      
      </xsd:element>
                                    
      
      <xsd:element dfdl:occursCountKind="implicit" minOccurs="0" name="GS_PipeSeparator" type="TYPE_GS_PipeSeparator"/>
                        
      
